.notice-label{margin-top:14px;}
.notice-input{box-sizing:border-box;width:100%;}
.notice-textarea{
  width:100%;
  min-height:180rpx;
  box-sizing:border-box;
  line-height:1.6;
}
.notice-action-row{
  margin-bottom:10px;
  flex-wrap:wrap;
}
.activity-image-grid{display:grid;grid-template-columns:repeat(1,1fr);gap:10px;margin-top:12px;}
.activity-image-item{position:relative;border-radius:16px;overflow:hidden;background:rgba(255,247,230,.56);border:1px solid rgba(167,58,32,.14);box-shadow:0 12px 26px rgba(65,44,25,.12);}
.activity-image-thumb{display:block;width:100%;height:320rpx;background:#EBD7B5;}
.activity-image-delete{position:absolute;right:8px;top:8px;min-width:0;height:30px;line-height:30px;padding:0 12px;border-radius:999px;background:rgba(19,20,18,.70);color:#F2E2C4;font-size:12px;}
.activity-image-delete::after{border:0;}
.activity-image-empty{margin-top:10px;padding:12px;border-radius:12px;background:rgba(255,247,230,.50);color:#655D4E;font-size:13px;line-height:1.6;}
