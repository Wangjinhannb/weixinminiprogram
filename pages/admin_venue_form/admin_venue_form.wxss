
.switch-line{display:flex;justify-content:space-between;align-items:center;padding:6px 0;}
.mini-btn{height:36px;font-size:12px;padding:0 12px;line-height:36px;}
.slot-row-card{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid rgba(167,58,32,.14);}
.slot-row-card:last-child{border-bottom:none;}
.slot-row-card-inner{padding:10px 0;}
.slot-main{flex:1;min-width:0;}
.slot-time{font-size:16px;font-weight:600;color:#131412;word-break:break-all;}
.slot-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;}
.slot-limit-row{display:flex;align-items:center;gap:10px;margin-top:10px;flex-wrap:wrap;}
.slot-limit-input{width:180rpx;height:68rpx;padding:0 20rpx;border-radius:12rpx;border:1px solid rgba(167,58,32,.18);background:rgba(255,247,230,.76);box-sizing:border-box;color:#131412;}
.override-card{margin-top:14px;padding:14px;border:1px solid rgba(167,58,32,.14);border-radius:12px;background:rgba(255,247,230,.50);}
.override-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;}
.override-date-block{flex:1;}
.override-date-input{min-height:40px;display:flex;align-items:center;}
.modal-mask{position:fixed;left:0;top:0;right:0;bottom:0;background:rgba(19,20,18,.48);display:flex;align-items:flex-end;justify-content:center;z-index:999;}
.modal{width:100%;max-width:720rpx;background:#F2E2C4;border-radius:24rpx 24rpx 0 0;padding:24rpx;box-sizing:border-box;max-height:90vh;border:1px solid rgba(167,58,32,.18);box-shadow:0 -18px 48px rgba(65,44,25,.20);}
.time-modal{display:flex;flex-direction:column;padding-bottom:calc(env(safe-area-inset-bottom) + 24rpx);}
.time-modal-head{display:flex;justify-content:space-between;align-items:flex-start;gap:16rpx;}
.time-modal-close{font-size:26rpx;color:#655D4E;line-height:40rpx;padding:4rpx 0;white-space:nowrap;}
.time-modal-body{flex:1;min-height:0;max-height:calc(90vh - 180rpx);margin-top:12rpx;}
.modal-title{font-size:18px;font-weight:600;color:#131412;}
.modal-actions{display:flex;gap:12px;margin-top:16px;}
.modal-actions-sticky{position:sticky;bottom:0;background:#F2E2C4;padding-top:16rpx;border-top:1px solid rgba(167,58,32,.14);}
.time-modal-section{margin-top:14px;}
.time-selected{font-size:18px;font-weight:600;color:#131412;margin:8px 0;}
.pv{width:100%;height:176px;background:rgba(255,247,230,.56);border-radius:12px;}
.pv-3col{height:176px;}
.pv-item{line-height:44px;text-align:center;color:#131412;}
.selection-text{margin-top:12px;color:#655D4E;font-size:14px;}
.conflict-box{margin-top:10px;padding:10px 12px;background:rgba(167,58,32,.10);border-radius:10px;}
.conflict-text{color:#A73A20;font-size:13px;line-height:1.6;}
.time-modal-tail-space{height:12rpx;}

.venue-image-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-top:2px;}
.venue-image-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:12px;}
.venue-image-item{position:relative;border-radius:12px;overflow:hidden;background:rgba(255,247,230,.56);border:1px solid rgba(167,58,32,.14);}
.venue-image-thumb{display:block;width:100%;height:150rpx;background:#EBD7B5;}
.venue-image-delete{position:absolute;right:6px;top:6px;min-width:0;height:28px;line-height:28px;padding:0 10px;border-radius:999px;background:rgba(19,20,18,.70);color:#F2E2C4;font-size:12px;}
.venue-image-delete::after{border:0;}
.venue-image-empty{margin-top:10px;padding:12px;border-radius:12px;background:rgba(255,247,230,.50);color:#655D4E;font-size:13px;line-height:1.6;}
